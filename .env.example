# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

# Public site URL (no trailing slash). Required in production for Better Auth and SvelteKit CSRF.
# Local: http://localhost:5173
# Fly.io: fly secrets set ORIGIN=https://YOUR_APP.fly.dev
ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
